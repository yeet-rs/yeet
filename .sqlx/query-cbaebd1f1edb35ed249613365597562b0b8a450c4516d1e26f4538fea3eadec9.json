  "query": "\n        SELECT\n            osl.id,\n            osn.host_identifier,\n            osl.unix_time,\n            osl.filename,\n            osl.line,\n            osl.message,\n            osl.severity,\n            osl.version,\n            osl.received_time as \"received_time: jiff_sqlx::Timestamp\"\n\n        FROM osquery_status_log osl\n        JOIN osquery_nodes osn on osl.node_id = osn.id\n        WHERE osl.splunk_status = $1",
